generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  detectado
  en_analisis
  aprobado
  campana_activa
  escalar
  ajustar
  pausado
  descartado
  ganador
}

enum CampaignStatus {
  pendiente
  activa
  en_revision
  escalada
  pausada
  finalizada
}

enum LogisticComplexity {
  baja
  media
  alta
}

enum CampaignChannel {
  meta_ads
  organico
  whatsapp
  catalogo
  tiktok_ads
}

enum DecisionType {
  escalar
  ajustar
  pausar
  descartar
  mantener_test
}

enum SyncStatus {
  success
  error
}

model Product {
  id                    String                @id @default(cuid())
  name                  String
  dropiCode             String?               @map("dropi_code")
  dropiUrl              String?               @map("dropi_url")
  productUrl            String?               @map("product_url")
  supplierUrl           String?               @map("supplier_url")
  supplierName          String?               @map("supplier_name")
  supplierCost          Decimal               @default(0) @map("supplier_cost") @db.Decimal(12, 2)
  marketPrice           Decimal?              @map("market_price") @db.Decimal(12, 2)
  marketPriceLow        Decimal?              @map("market_price_low") @db.Decimal(12, 2)
  marketPriceAverage    Decimal?              @map("market_price_average") @db.Decimal(12, 2)
  marketPriceHigh       Decimal?              @map("market_price_high") @db.Decimal(12, 2)
  idealSalePrice        Decimal               @default(0) @map("ideal_sale_price") @db.Decimal(12, 2)
  minSalePrice          Decimal?              @map("min_sale_price") @db.Decimal(12, 2)
  stock                 Int                   @default(0)
  category              String?
  niche                 String?
  wooProductId          String?               @map("woo_product_id")
  wooSku                String?               @map("woo_sku")
  logisticComplexity    LogisticComplexity    @default(media) @map("logistic_complexity")
  wowScore              Int                   @default(1) @map("wow_score")
  supplierScore         Int                   @default(1) @map("supplier_score")
  contentScore          Int                   @default(1) @map("content_score")
  hasRealSalesData      Boolean               @default(false) @map("has_real_sales_data")
  isPriceCompetitive    Boolean               @default(false) @map("is_price_competitive")
  status                ProductStatus         @default(detectado)
  priorityScore         Int                   @default(0) @map("priority_score")
  observations          String?
  mainImageUrl          String?               @map("main_image_url")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  financials            ProductFinancial[]
  campaigns             Campaign[]
  campaignSales         CampaignSale[]
  decisionLogs          DecisionLog[]

  @@map("products")
}

model ProductFinancial {
  id                    String   @id @default(cuid())
  productId             String   @map("product_id")
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierCost          Decimal  @map("supplier_cost") @db.Decimal(12, 2)
  salePrice             Decimal  @map("sale_price") @db.Decimal(12, 2)
  extraCosts            Decimal  @default(0) @map("extra_costs") @db.Decimal(12, 2)
  adInvestment          Decimal  @default(0) @map("ad_investment") @db.Decimal(12, 2)
  targetSales           Int      @default(1) @map("target_sales")
  grossMargin           Decimal  @map("gross_margin") @db.Decimal(12, 2)
  grossMarginPercent    Decimal  @map("gross_margin_percent") @db.Decimal(8, 2)
  breakEvenCpa          Decimal  @map("break_even_cpa") @db.Decimal(12, 2)
  plannedCpa            Decimal  @default(0) @map("planned_cpa") @db.Decimal(12, 2)
  breakEvenRoas         Decimal  @map("break_even_roas") @db.Decimal(12, 2)
  targetProfit          Decimal  @default(100) @map("target_profit") @db.Decimal(12, 2)
  projectedProfit       Decimal  @default(0) @map("projected_profit") @db.Decimal(12, 2)
  salesNeededForTarget  Int      @map("sales_needed_for_target")
  createdAt             DateTime @default(now()) @map("created_at")

  @@map("product_financials")
}

model Campaign {
  id             String            @id @default(cuid())
  productId      String            @map("product_id")
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  channel        CampaignChannel
  status         CampaignStatus    @default(pendiente)
  startDate      DateTime?         @map("start_date")
  endDate        DateTime?         @map("end_date")
  plannedBudget  Decimal           @default(0) @map("planned_budget") @db.Decimal(12, 2)
  realSpend      Decimal           @default(0) @map("real_spend") @db.Decimal(12, 2)
  salesGoal      Int               @default(1) @map("sales_goal")
  profitGoal     Decimal           @default(100) @map("profit_goal") @db.Decimal(12, 2)
  mainHook       String?           @map("main_hook")
  salesAngle     String?           @map("sales_angle")
  offer          String?
  cta            String?
  creativeUrl    String?           @map("creative_url")
  adUrl          String?           @map("ad_url")
  responsible    String?
  observations   String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  sales          CampaignSale[]
  metrics        CampaignMetric[]
  decisionLogs   DecisionLog[]

  @@map("campaigns")
}

model CampaignSale {
  id             String    @id @default(cuid())
  campaignId     String?   @map("campaign_id")
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  productId      String    @map("product_id")
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  wooOrderId     String    @map("woo_order_id")
  wooOrderStatus String    @map("woo_order_status")
  quantity       Int
  unitPrice      Decimal   @map("unit_price") @db.Decimal(12, 2)
  lineTotal      Decimal   @map("line_total") @db.Decimal(12, 2)
  orderDate      DateTime  @map("order_date")
  syncedAt       DateTime  @default(now()) @map("synced_at")

  @@unique([wooOrderId, productId])
  @@map("campaign_sales")
}

model CampaignMetric {
  id              String   @id @default(cuid())
  campaignId      String   @map("campaign_id")
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date            DateTime
  spend           Decimal  @default(0) @db.Decimal(12, 2)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  messages        Int      @default(0)
  sales           Int      @default(0)
  revenue         Decimal  @default(0) @db.Decimal(12, 2)
  estimatedProfit Decimal  @default(0) @map("estimated_profit") @db.Decimal(12, 2)
  cpa             Decimal  @default(0) @db.Decimal(12, 2)
  roas            Decimal  @default(0) @db.Decimal(12, 2)
  conversionRate  Decimal  @default(0) @map("conversion_rate") @db.Decimal(8, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("campaign_metrics")
}

model DecisionLog {
  id          String       @id @default(cuid())
  productId   String       @map("product_id")
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  campaignId  String?      @map("campaign_id")
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  decision    DecisionType
  reason      String
  scoreBefore Int?         @map("score_before")
  scoreAfter  Int?         @map("score_after")
  createdBy   String?      @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("decision_logs")
}

model SyncLog {
  id             String     @id @default(cuid())
  status         SyncStatus
  importedOrders Int        @default(0) @map("imported_orders")
  importedLines  Int        @default(0) @map("imported_lines")
  errorMessage   String?    @map("error_message")
  syncedAt       DateTime   @default(now()) @map("synced_at")

  @@map("sync_logs")
}

model UnmatchedWooCommerceProduct {
  id             String   @id @default(cuid())
  wooProductId   String?  @map("woo_product_id")
  wooSku         String?  @map("woo_sku")
  wooOrderId     String   @map("woo_order_id")
  name           String?
  quantity       Int      @default(0)
  lineTotal      Decimal  @default(0) @map("line_total") @db.Decimal(12, 2)
  orderDate      DateTime @map("order_date")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("unmatched_woocommerce_products")
}
