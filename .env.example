# API
PORT="4000"
CORS_ORIGIN="http://localhost:5173"
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_JWKS_URL="https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json"

# Frontend
VITE_API_URL="http://localhost:4000/api"
VITE_SUPABASE_URL="https://PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Supabase / PostgreSQL
# Use DATABASE_URL for the pooled/runtime connection.
# Use DIRECT_URL for Prisma migrations against Supabase.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# WooCommerce REST API
# Create these in WooCommerce > Settings > Advanced > REST API.
WOOCOMMERCE_BASE_URL="https://kiosko7.com"
WOOCOMMERCE_CONSUMER_KEY="ck_..."
WOOCOMMERCE_CONSUMER_SECRET="cs_..."
